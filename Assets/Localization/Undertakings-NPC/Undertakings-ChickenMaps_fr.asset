  m_TableData:
  - m_Id: 17116222266597400
    m_Localized: "Recoltes toutes les pi\xE8ces de la Carte Aviaire"
    m_Metadata:
      m_Items: []
  - m_Id: 17116225743675400
    m_Localized: "Il y a des poules ind\xE9pendant dans ces contr\xE9es ! Elles savent
      o\xF9 tu te trouves. Trouve-les et peut-\xEAtre qu'elles te montres o\xF9 tu
      es !"
    m_Metadata:
      m_Items: []
  - m_Id: 17116228755185700
    m_Localized: "T'as rassembl\xE9 tous les morceaux de la carte aviaire ! Maintenant,
      tu sauras toujours qui tu es... Je veux dire o\xF9 tu es !"
    m_Metadata:
      m_Items: []
